# =========================
# .env.example (template)
# =========================
# Tip: Copy this file to .env and fill in your actual values.
# Do not commit your .env file to git.

# ===== General =====
TZ=Europe/Vienna             # Example: Europe/Vienna
PUID=1000                    # Your NAS user ID (e.g., your admin user ID)
PGID=100                     # Your NAS group ID (e.g., administrators group ID)

# ===== NordVPN / OpenVPN (service credentials) =====
OPENVPN_CONFIG_COUNTRIES=austria,switzerland,germany,slovakia,czech_republic,slovenia,hungary,italy,liechtenstein  # Comma-separated country profiles for VPN
NORDVPN_USER=your_nordvpn_username                   # Your NordVPN username
NORDVPN_PASS=your_nordvpn_password                   # Your NordVPN password
NORDVPN_COUNTRY=AT                                   # Default country code (e.g., AT for Austria)

# ===== Local network =====
LOCAL_NETWORK=192.168.178.0/24                       # Your local network range

# ===== Transmission RPC auth =====
TRANSMISSION_RPC_USER=your_rpc_username              # Transmission RPC username
TRANSMISSION_RPC_PASSWORD=your_rpc_password          # Transmission RPC password

# ===== Cloudflare Tunnel =====
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token # Your Cloudflare Tunnel token

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token           # Your Telegram bot token
TELEGRAM_CHAT_ID=your_telegram_chat_id               # Your Telegram chat ID

# ===== Gmail SMTP =====
SMTP_HOST=smtp.gmail.com                             # SMTP host (Gmail example)
SMTP_PORT=587                                        # SMTP port (587 for TLS)
SMTP_USER=your_gmail_username                        # Your Gmail address (as username)
SMTP_PASS=your_gmail_app_password                    # Your Gmail app password
SMTP_FROM=your_gmail_from_address                    # From address (usually same as user)
SMTP_TO=recipient_email_address                      # Recipient email for notifications

